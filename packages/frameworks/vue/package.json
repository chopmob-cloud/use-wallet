  },
  "devDependencies": {
    "algosdk": "3.5.2",
    "tsup": "8.5.1",
    "typescript": "5.9.3",
    "vue": "3.5.27"
  },
  "peerDependencies": {
    "algosdk": "^3.0.0",
    "vue": "^3.0.0"
  }
