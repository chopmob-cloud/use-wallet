{
  "name": "@txnlab/use-wallet-walletconnect",
  "version": "5.0.0-rc.0",
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "description": "WalletConnect adapter for @txnlab/use-wallet",
  "author": "Doug Richar <drichar@gmail.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/txnlab/use-wallet.git",
    "directory": "packages/wallets/walletconnect"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "peerDependencies": {
    "@txnlab/use-wallet": "^5.0.0",
    "algosdk": "^3.0.0"
  },
  "dependencies": {
    "@walletconnect/sign-client": "^2.17.0",
    "@walletconnect/modal": "^2.7.0",
    "@walletconnect/types": "^2.17.0"
  },
  "devDependencies": {
    "@txnlab/use-wallet": "workspace:*",
    "algosdk": "3.5.2",
    "tsup": "8.5.1",
    "typescript": "5.9.3"
  },
  "scripts": {
    "build": "tsup",
    "start": "tsup src/index.ts --watch",
    "test": "vitest run",
    "test:watch": "vitest --watch",
    "lint": "eslint -c \"../../../.eslintrc.json\" \"**/*.{js,ts}\"",
    "typecheck": "tsc --noEmit"
  }
}
