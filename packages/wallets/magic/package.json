{
  "name": "@txnlab/use-wallet-magic",
  "version": "5.0.0-rc.0",
  "description": "Magic wallet adapter for @txnlab/use-wallet",
  "author": "Doug Richar <drichar@gmail.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/txnlab/use-wallet.git",
    "directory": "packages/wallets/magic"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": ["dist"],
  "peerDependencies": {
    "@txnlab/use-wallet": "^5.0.0",
    "algosdk": "^3.0.0"
  },
  "dependencies": {
    "magic-sdk": "^33.5.0",
    "@magic-ext/algorand": "^28.4.0"
  },
  "devDependencies": {
    "@txnlab/use-wallet": "workspace:*",
    "algosdk": "3.5.2",
    "tsup": "8.5.1",
    "typescript": "5.9.3"
  },
  "scripts": {
    "build": "tsup",
    "start": "tsup src/index.ts --watch",
    "test": "vitest run",
    "test:watch": "vitest --watch",
    "lint": "eslint -c \"../../../.eslintrc.json\" \"**/*.{js,ts}\"",
    "typecheck": "tsc --noEmit"
  }
}
